GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite

# OCR speed/accuracy tuning
# Balanced default:
OCR_LANG=hun+eng
OCR_MAX_SIDE=1400
OCR_TESSERACT_CONFIG=--oem 1 --psm 6 -c load_system_dawg=0 -c load_freq_dawg=0

# Faster option (less accurate on Hungarian text):
# OCR_LANG=eng
# OCR_MAX_SIDE=1200
